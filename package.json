{
  "name": "@gfd/monorepo",
  "version": "1.0.0",
  "description": "General Framework for Development - 通用开发框架",
  "type": "module",
  "scripts": {
    "build": "tsc -b",
    "dev": "pnpm -r dev",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write .",
    "clean": "pnpm -r clean && rm -rf node_modules dist",
    "release": "pnpm build && changeset publish"
  },
  "keywords": [
    "framework",
    "plugin-system",
    "modular",
    "i18n",
    "typescript",
    "harness"
  ],
  "author": "GFD Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0",
  "devDependencies": {
    "@changesets/cli": "^2.27.1",
    "@types/node": "^20.19.37",
    "@typescript-eslint/eslint-plugin": "^6.19.0",
    "@typescript-eslint/parser": "^6.19.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.2.4",
    "typescript": "^5.9.3",
    "vitest": "^1.2.1"
  },
  "pnpm": {
    "workspaces": [
      "packages/*",
      "examples/*"
    ]
  },
  "dependencies": {
    "dotenv": "^17.3.1",
    "reflect-metadata": "^0.2.2"
  }
}
